<% content_for :title, "Practice — #{@song_part.song.title}" %>

<div style="margin-bottom:16px;">
  <%= link_to "← Back to Song", song_path(@song_part.song), style: "color:#666688;text-decoration:none;font-size:0.9rem;font-family:'Space Grotesk',sans-serif;" %>
</div>

<h2 style="margin-bottom:4px;font-size:1.6rem;font-weight:700;letter-spacing:-0.01em;"><%= @song_part.song.title %></h2>
<p style="color:#666688;margin:0 0 24px;font-family:'Space Grotesk',sans-serif;font-size:0.9rem;"><%= @song_part.name %> · <%= @song_part.note_count %> notes · <%= @song_part.song.tempo_bpm %> BPM</p>

<% beats_per_measure = @song_part.song.time_signature&.split("/")&.first&.to_i || 4 %>
<div data-controller="midi practice"
     data-practice-notes-value="<%= @song_part.notes.to_json %>"
     data-practice-session-id-value="<%= @session.id %>"
     data-practice-song-part-id-value="<%= @song_part.id %>"
     data-practice-bpm-value="<%= @song_part.song.tempo_bpm %>"
     data-practice-beats-per-measure-value="<%= beats_per_measure %>"
     data-practice-keyboard-outlet=".keyboard-wrapper"
     data-practice-staff-outlet=".staff-wrapper">

  <%# Control panel %>
  <div class="neon-card" style="text-align:center;padding:24px;margin-bottom:24px;">
    <div style="font-size:2.5rem;color:#00f0ff;min-height:3rem;font-family:'Space Grotesk',sans-serif;font-weight:700;text-shadow:0 0 12px rgba(0,240,255,0.4);" data-practice-target="countDisplay"></div>
    <p style="color:#a0a0cc;margin:8px 0 0;font-size:0.85rem;display:none;" data-practice-target="resultDisplay"></p>

    <div style="margin-top:16px;display:flex;justify-content:center;gap:12px;">
      <button data-action="click->practice#start"
              data-practice-target="startButton"
              class="neon-btn-primary">
        START PRACTICE
      </button>
      <button data-action="click->practice#restart"
              data-practice-target="restartButton"
              class="neon-btn-secondary"
              style="display:none;">
        RESTART
      </button>
    </div>

    <div style="margin-top:20px;">
      <div style="background:#1a1a2e;border-radius:4px;height:6px;overflow:hidden;">
        <div data-practice-target="progressBar"
             style="background:linear-gradient(90deg,#ff00ff,#00f0ff);height:100%;width:0%;transition:width 0.2s;border-radius:4px;"></div>
      </div>
      <p style="color:#666688;font-size:0.8rem;margin:8px 0 0;font-family:'Space Grotesk',sans-serif;" data-practice-target="progressText">
        0 / <%= @song_part.note_count %> notes
      </p>
    </div>
  </div>

  <%# Staff notation display %>
  <div class="staff-wrapper" data-controller="staff"
       data-staff-beats-per-measure-value="<%= beats_per_measure %>"
       style="background:#111128;border:1px solid #2a2a44;border-radius:8px;margin-bottom:24px;min-height:150px;overflow:hidden;">
  </div>

  <%# Virtual keyboard %>
  <div class="keyboard-wrapper" data-controller="keyboard" style="margin-bottom:24px;"></div>

  <%# MIDI status %>
  <div style="text-align:center;margin-bottom:16px;">
    <span data-midi-target="status" style="color:#666688;font-size:0.8rem;font-family:'Space Grotesk',sans-serif;">MIDI: Not connected</span>
  </div>

  <%# Session complete Turbo Frame (populated by server on completion) %>
  <turbo-frame id="session_complete"></turbo-frame>
</div>
