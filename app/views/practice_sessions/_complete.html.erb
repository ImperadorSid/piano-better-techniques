<div id="session_complete" style="background:#111128;border:1px solid rgba(57,255,20,0.25);border-radius:8px;padding:32px;text-align:center;margin-top:24px;box-shadow:0 0 20px rgba(57,255,20,0.08);">
  <h3 style="color:#39ff14;margin:0 0 8px;font-family:'Space Grotesk',sans-serif;font-size:1.1rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;text-shadow:0 0 8px rgba(57,255,20,0.4);">Session Complete!</h3>

  <div style="font-size:3.5rem;font-weight:800;color:#00f0ff;margin:16px 0;font-family:'Space Grotesk',sans-serif;text-shadow:0 0 15px rgba(0,240,255,0.4);">
    <%= session.composite_score&.round(1) || session.accuracy_pct.to_f.round(1) %>
  </div>
  <p style="color:#666688;margin:0 0 24px;font-family:'Space Grotesk',sans-serif;font-size:0.8rem;text-transform:uppercase;letter-spacing:0.1em;">Composite Score</p>

  <%# Score breakdown bars %>
  <div style="max-width:380px;margin:0 auto;text-align:left;">
    <% [
      ["Accuracy", session.accuracy_pct],
      ["Timing", session.timing_score],
      ["Dynamics", session.velocity_score]
    ].each do |label, score| %>
      <div style="margin-bottom:14px;">
        <div style="display:flex;justify-content:space-between;margin-bottom:5px;">
          <span style="color:#a0a0cc;font-size:0.85rem;font-family:'Space Grotesk',sans-serif;font-weight:600;"><%= label %></span>
          <% if score %>
            <% color = score >= 80 ? "#39ff14" : score >= 50 ? "#ffff00" : "#ff2255" %>
            <span style="color:<%= color %>;font-size:0.85rem;font-weight:700;font-family:'Space Grotesk',sans-serif;"><%= score.round(1) %></span>
          <% else %>
            <span style="color:#444466;font-size:0.85rem;">—</span>
          <% end %>
        </div>
        <div style="background:#1a1a2e;border-radius:4px;height:6px;overflow:hidden;">
          <% bar_pct = score ? [score, 100].min : 0 %>
          <% bar_color = score && score >= 80 ? "#39ff14" : score && score >= 50 ? "#ffff00" : "#ff2255" %>
          <div style="background:<%= bar_color %>;height:100%;width:<%= bar_pct %>%;border-radius:4px;box-shadow:0 0 6px <%= bar_color %>44;"></div>
        </div>
      </div>
    <% end %>
  </div>

  <p style="color:#666688;margin:20px 0 0;font-size:0.85rem;font-family:'Space Grotesk',sans-serif;">
    <%= session.correct_notes %> correct · <%= session.incorrect_notes %> incorrect ·
    <%= session.notes_reached %> / <%= session.total_notes %> notes reached
  </p>
  <%= link_to "PRACTICE AGAIN", song_path(session.song), class: "neon-btn-success", style: "margin-top:16px;" %>
</div>
