<% content_for :title, "Analysis — #{@song.title}" %>

<div style="margin-bottom:16px;">
  <%= link_to "← Back to Song", song_path(@song), style: "color:#666688;text-decoration:none;font-size:0.9rem;font-family:'Space Grotesk',sans-serif;" %>
</div>

<div style="display:flex;justify-content:space-between;align-items:start;margin-bottom:4px;">
  <h1 style="margin:0;font-size:2rem;font-weight:800;letter-spacing:-0.02em;"><%= @song.title %> <span style="color:#666688;font-weight:400;">— Analysis</span></h1>
  <% if @song_analysis && @song_analysis.ai_generated? %>
    <%= button_to "REGENERATE", regenerate_song_path(@song), method: :post, class: "neon-btn-primary", style: "white-space:nowrap;padding:8px 20px;font-size:0.85rem;" %>
  <% end %>
</div>
<p style="color:#a0a0cc;margin:0 0 32px;"><%= @song.composer.presence || "Unknown composer" %></p>

<% if @song_analysis.nil? %>
  <div class="neon-card" style="padding:40px;text-align:center;">
    <p style="color:#a0a0cc;">No analysis available for this song yet.</p>
  </div>
<% else %>

  <%# ── AI-Generated Overview ─────────────────────────────────────────────── %>
  <%= turbo_stream_from "song_overview_#{@song.id}" %>
  <div id="ai_overview">
    <%= render "ai_overview", song_analysis: @song_analysis %>
  </div>

  <%# ── Structured Data ────────────────────────────────────────────────────── %>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-bottom:32px;">

    <%# Chord Progression %>
    <div class="neon-card">
      <h3 style="margin:0 0 16px;color:#a0a0cc;font-size:1rem;text-transform:uppercase;letter-spacing:0.08em;">Chord Progression</h3>
      <% if @song_analysis.chord_progressions.any? %>
        <div style="display:flex;flex-wrap:wrap;gap:8px;">
          <% @song_analysis.chord_progressions.each do |chord| %>
            <div style="background:#1a1a2e;border:1px solid #ff00ff33;border-radius:6px;padding:10px 14px;text-align:center;">
              <div style="color:#ff44cc;font-size:1.1rem;font-weight:bold;font-family:'Space Grotesk',sans-serif;"><%= chord["chord"] %></div>
              <div style="color:#666688;font-size:0.7rem;font-family:'Space Grotesk',sans-serif;">Beat <%= chord["beat"] %></div>
              <div style="color:#666688;font-size:0.7rem;"><%= chord["quality"] %></div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p style="color:#666688;">No chord data available.</p>
      <% end %>
    </div>

    <%# Difficulty Sections %>
    <div class="neon-card">
      <h3 style="margin:0 0 16px;color:#a0a0cc;font-size:1rem;text-transform:uppercase;letter-spacing:0.08em;">Difficulty Sections</h3>
      <% if @song_analysis.difficulty_sections.any? %>
        <% colors = ["rgba(57,255,20,0.12)", "rgba(255,255,0,0.1)", "rgba(255,140,0,0.1)", "rgba(255,34,85,0.1)", "rgba(255,0,255,0.1)"] %>
        <% borders = ["rgba(57,255,20,0.3)", "rgba(255,255,0,0.3)", "rgba(255,140,0,0.3)", "rgba(255,34,85,0.3)", "rgba(255,0,255,0.3)"] %>
        <% text_colors = ["#39ff14", "#ffff00", "#ff8c00", "#ff2255", "#ff00ff"] %>
        <% @song_analysis.difficulty_sections.each do |section| %>
          <% level = section["level"].to_i %>
          <div style="background:<%= colors[level - 1] || '#1a1a2e' %>;border:1px solid <%= borders[level - 1] || '#2a2a44' %>;border-radius:6px;padding:10px 14px;margin-bottom:8px;">
            <div style="color:#e0e0ff;font-weight:600;font-family:'Space Grotesk',sans-serif;"><%= section["label"] %></div>
            <div style="color:#a0a0cc;font-size:0.85rem;">
              Beats <%= section["start_beat"] %> – <%= section["end_beat"] %> ·
              <span style="color:<%= text_colors[level - 1] || '#a0a0cc' %>;font-weight:600;">Level <%= level %>/5</span>
            </div>
          </div>
        <% end %>
      <% else %>
        <p style="color:#666688;">No section data available.</p>
      <% end %>
    </div>

  </div>

  <%# Dynamics %>
  <div class="neon-card" style="margin-bottom:24px;">
    <h3 style="margin:0 0 16px;color:#a0a0cc;font-size:1rem;text-transform:uppercase;letter-spacing:0.08em;">Dynamics Map</h3>
    <% if @song_analysis.dynamics_map.any? %>
      <div style="display:flex;flex-wrap:wrap;gap:8px;">
        <% @song_analysis.dynamics_map.each do |dyn| %>
          <span style="background:rgba(57,255,20,0.08);border:1px solid rgba(57,255,20,0.2);color:#39ff14;padding:6px 12px;border-radius:4px;font-size:0.85rem;font-family:'Space Grotesk',sans-serif;">
            <strong><%= dyn["marking"] %></strong>
            <span style="color:#666688;font-size:0.75rem;margin-left:6px;">beat <%= dyn["beat"] %> · vel <%= dyn["velocity_avg"] %></span>
          </span>
        <% end %>
      </div>
    <% else %>
      <p style="color:#666688;">No dynamics data available.</p>
    <% end %>
  </div>

  <%# Hand Separation %>
  <% if @song_analysis.hand_separation.any? %>
    <div class="neon-card">
      <h3 style="margin:0 0 12px;color:#a0a0cc;font-size:1rem;text-transform:uppercase;letter-spacing:0.08em;">Hand Separation</h3>
      <p style="color:#a0a0cc;margin:0;font-size:0.9rem;">
        Split point: <span style="color:#00f0ff;font-weight:600;font-family:'Space Grotesk',sans-serif;">MIDI <%= @song_analysis.hand_separation["split_midi"] %></span>
        <span style="color:#666688;">(<%= @song_analysis.hand_separation["method"]&.humanize %>)</span>
      </p>
    </div>
  <% end %>

<% end %>
