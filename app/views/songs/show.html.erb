<% content_for :title, "#{@song.title} — Piano Learner" %>

<div style="margin-bottom:20px;">
  <%= link_to "← Back to Library", songs_path, style: "color:#666688;text-decoration:none;font-size:0.9rem;font-family:'Space Grotesk',sans-serif;" %>
</div>

<!-- BADGE_PLACEMENT -->
<div style="display:flex;justify-content:space-between;align-items:start;margin-bottom:28px;">
  <div>
    <h1 style="margin:0 0 4px;font-size:2rem;font-weight:800;letter-spacing:-0.02em;"><%= @song.title %></h1>
    <div style="display:flex;align-items:center;gap:10px;margin-top:4px;">
      <p style="color:#a0a0cc;margin:0;font-size:1rem;"><%= @song.composer.presence || "Unknown composer" %></p>
      <span style="display:inline-block;padding:3px 10px;border-radius:4px;background:rgba(255,0,255,0.12);color:#ff44cc;font-family:'Space Grotesk',sans-serif;font-size:0.7rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;border:1px solid rgba(255,0,255,0.25);text-shadow:0 0 6px rgba(255,0,255,0.3);"><%= @song.difficulty_label %></span>
    </div>
  </div>
  <div style="display:flex;gap:16px;align-items:center;">
    <%= link_to analyze_song_path(@song), style: "display:inline-flex;align-items:center;gap:6px;padding:8px 18px;border-radius:6px;background:linear-gradient(135deg,rgba(0,240,255,0.15),rgba(0,240,255,0.05));color:#00f0ff;font-family:'Space Grotesk',sans-serif;font-size:0.85rem;font-weight:600;letter-spacing:0.05em;text-decoration:none;border:1px solid rgba(0,240,255,0.3);transition:all 0.2s;" do %>ANALYSIS<% end %>
    <%= link_to song_path(@song), data: { turbo_method: :delete, turbo_confirm: "Delete this song?" }, style: "display:inline-flex;align-items:center;gap:4px;padding:6px 14px;border-radius:6px;background:rgba(255,34,85,0.08);color:#ff2255;font-family:'Space Grotesk',sans-serif;font-size:0.8rem;font-weight:600;letter-spacing:0.03em;text-decoration:none;border:1px solid rgba(255,34,85,0.2);transition:all 0.2s;" do %>DELETE<% end %>
  </div>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:32px;">
  <div class="neon-card" style="text-align:center;padding:20px;">
    <div style="font-size:1.8rem;font-weight:700;color:#00f0ff;font-family:'Space Grotesk',sans-serif;text-shadow:0 0 8px rgba(0,240,255,0.3);"><%= @song.tempo_bpm %></div>
    <div style="color:#666688;font-size:0.8rem;text-transform:uppercase;letter-spacing:0.1em;font-family:'Space Grotesk',sans-serif;margin-top:4px;">BPM</div>
  </div>
  <div class="neon-card" style="text-align:center;padding:20px;">
    <div style="font-size:1.8rem;font-weight:700;color:#00f0ff;font-family:'Space Grotesk',sans-serif;text-shadow:0 0 8px rgba(0,240,255,0.3);"><%= @song.key_signature %></div>
    <div style="color:#666688;font-size:0.8rem;text-transform:uppercase;letter-spacing:0.1em;font-family:'Space Grotesk',sans-serif;margin-top:4px;">Key</div>
  </div>
  <div class="neon-card" style="text-align:center;padding:20px;">
    <div style="font-size:1.8rem;font-weight:700;color:#00f0ff;font-family:'Space Grotesk',sans-serif;text-shadow:0 0 8px rgba(0,240,255,0.3);"><%= @song.time_signature %></div>
    <div style="color:#666688;font-size:0.8rem;text-transform:uppercase;letter-spacing:0.1em;font-family:'Space Grotesk',sans-serif;margin-top:4px;">Time</div>
  </div>
</div>

<% if @song_analysis %>
  <div class="neon-card" style="margin-bottom:32px;">
    <h3 style="margin:0 0 14px;color:#a0a0cc;font-size:1rem;text-transform:uppercase;letter-spacing:0.08em;">Chord Progression</h3>
    <div style="display:flex;flex-wrap:wrap;gap:8px;">
      <% @song_analysis.chord_progressions.each do |chord| %>
        <span style="background:#1a1a2e;border:1px solid #ff00ff44;color:#ff44cc;padding:6px 14px;border-radius:20px;font-size:0.85rem;font-family:'Space Grotesk',sans-serif;">
          <%= chord["chord"] %><span style="color:#666688;font-size:0.7rem;margin-left:6px;">beat <%= chord["beat"] %></span>
        </span>
      <% end %>
    </div>
  </div>
<% end %>

<h2 style="margin-bottom:16px;font-size:1.3rem;font-weight:700;letter-spacing:-0.01em;">Practice Parts</h2>

<% if @song_parts.empty? %>
  <p style="color:#666688;">No practice parts available.</p>
<% else %>
  <div style="display:flex;flex-direction:column;gap:12px;">
    <% @song_parts.each do |part| %>
      <div class="neon-card" style="display:flex;justify-content:space-between;align-items:center;">
        <div>
          <h3 style="margin:0 0 4px;font-size:1.05rem;color:#e0e0ff;"><%= part.name %></h3>
          <p style="color:#666688;margin:0;font-size:0.85rem;font-family:'Space Grotesk',sans-serif;">
            <%= part.hand.capitalize %> hand · <%= part.note_count %> notes
          </p>
        </div>
        <%= button_to "START PRACTICE",
              song_part_practice_sessions_path(part),
              method: :post,
              class: "neon-btn-success" %>
      </div>
    <% end %>
  </div>
<% end %>
