<% content_for :title, "Import Song — Piano Learner" %>

<h1 style="margin-bottom:8px;">Import a Song</h1>
<p style="color:#888;margin-bottom:32px;">Upload a MIDI file or provide a URL to a song from the internet.</p>

<div style="background:#111;border:1px solid #333;border-radius:8px;padding:32px;max-width:600px;"
     data-controller="song-import">

  <%= form_with url: import_songs_path, method: :post, multipart: true do |f| %>

    <div style="margin-bottom:20px;">
      <%= f.label :title, "Song Title (optional)", style: "display:block;color:#b0b0dd;margin-bottom:6px;" %>
      <%= f.text_field :title,
            placeholder: "Leave blank to auto-detect from file",
            style: "width:100%;background:#1a1a2e;border:1px solid #444;color:#e0e0ff;padding:10px;border-radius:6px;box-sizing:border-box;" %>
    </div>

    <div style="margin-bottom:20px;">
      <label style="display:block;color:#b0b0dd;margin-bottom:6px;">Import from URL (ABC notation)</label>
      <%= f.url_field :source_url,
            placeholder: "e.g. thesession.org tune URL",
            style: "width:100%;background:#1a1a2e;border:1px solid #444;color:#e0e0ff;padding:10px;border-radius:6px;box-sizing:border-box;" %>
      <p style="color:#666;font-size:0.8rem;margin:6px 0 0;">Works with thesession.org tune URLs</p>
    </div>

    <div style="margin-bottom:24px;">
      <label style="display:block;color:#b0b0dd;margin-bottom:6px;">Or upload a MIDI file</label>
      <%= f.file_field :file,
            accept: ".mid,.midi",
            style: "color:#e0e0ff;" %>
    </div>

    <%= f.submit "Import Song",
          style: "background:#5555ff;color:white;padding:12px 28px;border-radius:6px;border:none;cursor:pointer;font-size:1rem;width:100%;" %>
  <% end %>

  <div data-song-import-target="status" style="display:none;margin-top:16px;color:#888;text-align:center;"></div>
</div>

<div style="margin-top:32px;max-width:600px;">
  <h3 style="color:#b0b0dd;margin-bottom:12px;">Supported sources</h3>
  <ul style="color:#888;line-height:1.8;">
    <li><strong style="color:#e0e0ff;">MIDI files (.mid)</strong> — Upload from your computer</li>
    <li><strong style="color:#e0e0ff;">The Session</strong> — Irish traditional music (ABC notation)</li>
  </ul>
</div>
