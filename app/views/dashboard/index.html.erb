<% content_for :title, "Dashboard — Piano Learner" %>

<div style="margin-bottom:32px;">
  <h1 style="margin:0 0 4px;font-size:2.5rem;font-weight:800;letter-spacing:-0.03em;">Dashboard</h1>
  <p style="color:#666688;text-transform:uppercase;letter-spacing:0.15em;font-size:0.8rem;font-family:'Space Grotesk',sans-serif;margin:0;">Your Progress Overview</p>
</div>

<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:32px;">
  <div class="neon-card" style="text-align:center;padding:24px;">
    <div style="font-size:2.2rem;font-weight:800;color:#00f0ff;font-family:'Space Grotesk',sans-serif;text-shadow:0 0 10px rgba(0,240,255,0.3);"><%= @total_sessions %></div>
    <div style="color:#666688;font-size:0.8rem;text-transform:uppercase;letter-spacing:0.1em;font-family:'Space Grotesk',sans-serif;margin-top:4px;">Sessions</div>
  </div>
  <div class="neon-card" style="text-align:center;padding:24px;">
    <div style="font-size:2.2rem;font-weight:800;color:#ff00ff;font-family:'Space Grotesk',sans-serif;text-shadow:0 0 10px rgba(255,0,255,0.3);"><%= @avg_accuracy %>%</div>
    <div style="color:#666688;font-size:0.8rem;text-transform:uppercase;letter-spacing:0.1em;font-family:'Space Grotesk',sans-serif;margin-top:4px;">Avg Accuracy</div>
  </div>
  <div class="neon-card" style="text-align:center;padding:24px;">
    <div style="font-size:2.2rem;font-weight:800;color:#39ff14;font-family:'Space Grotesk',sans-serif;text-shadow:0 0 10px rgba(57,255,20,0.3);"><%= @avg_score %></div>
    <div style="color:#666688;font-size:0.8rem;text-transform:uppercase;letter-spacing:0.1em;font-family:'Space Grotesk',sans-serif;margin-top:4px;">Avg Score</div>
  </div>
  <div class="neon-card" style="text-align:center;padding:24px;">
    <div style="font-size:2.2rem;font-weight:800;color:#ffff00;font-family:'Space Grotesk',sans-serif;text-shadow:0 0 10px rgba(255,255,0,0.3);"><%= @songs_practiced %></div>
    <div style="color:#666688;font-size:0.8rem;text-transform:uppercase;letter-spacing:0.1em;font-family:'Space Grotesk',sans-serif;margin-top:4px;">Songs Practiced</div>
  </div>
</div>

<% if @accuracy_chart_data.any? %>
  <div class="neon-card" style="padding:24px;margin-bottom:32px;">
    <h3 style="margin:0 0 16px;color:#a0a0cc;font-size:1rem;text-transform:uppercase;letter-spacing:0.08em;">Accuracy Over Time</h3>
    <div data-controller="progress-chart"
         data-progress-chart-sessions-value="<%= @accuracy_chart_data.to_json %>">
      <canvas id="accuracyChart" style="max-height:250px;"></canvas>
    </div>
  </div>
<% end %>

<h3 style="margin-bottom:16px;color:#a0a0cc;font-size:1rem;text-transform:uppercase;letter-spacing:0.08em;">Recent Sessions</h3>
<% if @recent_sessions.any? %>
  <div class="neon-card" style="padding:0;overflow:hidden;">
    <table style="width:100%;border-collapse:collapse;">
      <thead>
        <tr style="border-bottom:1px solid #2a2a44;">
          <th style="padding:14px 16px;color:#666688;font-size:0.75rem;text-align:left;font-family:'Space Grotesk',sans-serif;text-transform:uppercase;letter-spacing:0.1em;">Song</th>
          <th style="padding:14px 16px;color:#666688;font-size:0.75rem;text-align:left;font-family:'Space Grotesk',sans-serif;text-transform:uppercase;letter-spacing:0.1em;">Date</th>
          <th style="padding:14px 16px;color:#666688;font-size:0.75rem;text-align:left;font-family:'Space Grotesk',sans-serif;text-transform:uppercase;letter-spacing:0.1em;">Accuracy</th>
          <th style="padding:14px 16px;color:#666688;font-size:0.75rem;text-align:left;font-family:'Space Grotesk',sans-serif;text-transform:uppercase;letter-spacing:0.1em;">Score</th>
        </tr>
      </thead>
      <tbody>
        <% @recent_sessions.first(5).each_with_index do |session, i| %>
          <tr style="border-bottom:1px solid #1a1a2e;<%= i.even? ? 'background:#0d0d20;' : '' %>">
            <td style="padding:14px 16px;color:#e0e0ff;font-weight:500;"><%= session.song.title %></td>
            <td style="padding:14px 16px;font-size:0.85rem;">
              <span style="color:#a0a0cc;font-weight:500;"><%= session.created_at.strftime("%b %d") %></span>
              <span style="color:#a0a0cc;margin-left:6px;font-size:0.8rem;font-weight:300;font-family:monospace;"><%= session.created_at.strftime("%H:%M") %></span>
            </td>
            <td style="padding:14px 16px;">
              <% acc = session.accuracy_pct.to_f %>
              <span style="color:<%= acc >= 80 ? '#39ff14' : acc >= 50 ? '#ffff00' : '#ff2255' %>;font-weight:600;font-family:'Space Grotesk',sans-serif;<%= acc >= 80 ? 'text-shadow:0 0 6px rgba(57,255,20,0.4);' : '' %>"><%= "#{acc.round(1)}%" %></span>
            </td>
            <td style="padding:14px 16px;">
              <% if session.composite_score %>
                <% cs = session.composite_score.to_f %>
                <span style="color:<%= cs >= 80 ? '#39ff14' : cs >= 50 ? '#ffff00' : '#ff2255' %>;font-weight:600;font-family:'Space Grotesk',sans-serif;<%= cs >= 80 ? 'text-shadow:0 0 6px rgba(57,255,20,0.4);' : '' %>"><%= cs.round(1) %></span>
              <% else %>
                <span style="color:#444466;">—</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="neon-card" style="text-align:center;padding:40px;">
    <p style="color:#a0a0cc;">No sessions yet.</p>
    <%= link_to "START PRACTICING", songs_path, class: "neon-btn-primary", style: "margin-top:12px;" %>
  </div>
<% end %>
