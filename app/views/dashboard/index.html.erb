<% content_for :title, "Dashboard — Piano Learner" %>

<h1 style="margin-bottom:24px;">Dashboard</h1>

<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:32px;">
  <div style="background:#111;border:1px solid #333;border-radius:8px;padding:20px;text-align:center;">
    <div style="font-size:2rem;font-weight:bold;color:#7c7cff;"><%= @total_sessions %></div>
    <div style="color:#888;font-size:0.85rem;">Sessions Completed</div>
  </div>
  <div style="background:#111;border:1px solid #333;border-radius:8px;padding:20px;text-align:center;">
    <div style="font-size:2rem;font-weight:bold;color:#7c7cff;"><%= @avg_accuracy %>%</div>
    <div style="color:#888;font-size:0.85rem;">Avg Accuracy</div>
  </div>
  <div style="background:#111;border:1px solid #333;border-radius:8px;padding:20px;text-align:center;">
    <div style="font-size:2rem;font-weight:bold;color:#7c7cff;"><%= @avg_score %></div>
    <div style="color:#888;font-size:0.85rem;">Avg Score</div>
  </div>
  <div style="background:#111;border:1px solid #333;border-radius:8px;padding:20px;text-align:center;">
    <div style="font-size:2rem;font-weight:bold;color:#7c7cff;"><%= @songs_practiced %></div>
    <div style="color:#888;font-size:0.85rem;">Songs Practiced</div>
  </div>
</div>

<% if @accuracy_chart_data.any? %>
  <div style="background:#111;border:1px solid #333;border-radius:8px;padding:20px;margin-bottom:32px;">
    <h3 style="margin:0 0 16px;color:#b0b0dd;">Accuracy Over Time</h3>
    <div data-controller="progress-chart"
         data-progress-chart-sessions-value="<%= @accuracy_chart_data.to_json %>">
      <canvas id="accuracyChart" style="max-height:250px;"></canvas>
    </div>
  </div>
<% end %>

<h3 style="margin-bottom:12px;color:#b0b0dd;">Recent Sessions</h3>
<% if @recent_sessions.any? %>
  <table style="width:100%;border-collapse:collapse;">
    <thead>
      <tr style="color:#888;font-size:0.85rem;text-align:left;border-bottom:1px solid #333;">
        <th style="padding:8px 12px;">Song</th>
        <th style="padding:8px 12px;">Date</th>
        <th style="padding:8px 12px;">Accuracy</th>
        <th style="padding:8px 12px;">Score</th>
      </tr>
    </thead>
    <tbody>
      <% @recent_sessions.first(5).each do |session| %>
        <tr style="border-bottom:1px solid #222;">
          <td style="padding:10px 12px;color:#e0e0ff;"><%= session.song.title %></td>
          <td style="padding:10px 12px;color:#666;font-size:0.85rem;"><%= session.created_at.strftime("%b %d") %></td>
          <td style="padding:10px 12px;">
            <% acc = session.accuracy_pct.to_f %>
            <span style="color:<%= acc >= 80 ? '#90ee90' : acc >= 50 ? '#eeee90' : '#ee9090' %>"><%= "#{acc.round(1)}%" %></span>
          </td>
          <td style="padding:10px 12px;">
            <% if session.composite_score %>
              <% cs = session.composite_score.to_f %>
              <span style="color:<%= cs >= 80 ? '#90ee90' : cs >= 50 ? '#eeee90' : '#ee9090' %>"><%= cs.round(1) %></span>
            <% else %>
              <span style="color:#555;">—</span>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p style="color:#888;">No sessions yet. <%= link_to "Start practicing!", songs_path, style: "color:#7c7cff;" %></p>
<% end %>
