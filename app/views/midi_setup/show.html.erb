<% content_for :title, "MIDI Setup — Piano Learner" %>

<div style="margin-bottom:32px;">
  <h1 style="margin:0 0 4px;font-size:2.5rem;font-weight:800;letter-spacing:-0.03em;">MIDI Device Setup</h1>
  <p style="color:#666688;text-transform:uppercase;letter-spacing:0.15em;font-size:0.8rem;font-family:'Space Grotesk',sans-serif;margin:0;">Test Your Connection</p>
</div>

<div style="max-width:700px;">
  <div data-controller="midi"
       class="neon-card" style="padding:32px;margin-bottom:24px;">

    <div style="display:flex;align-items:center;gap:12px;margin-bottom:24px;">
      <div style="width:12px;height:12px;border-radius:50%;background:#444466;box-shadow:0 0 6px rgba(68,68,102,0.4);" data-midi-target="statusDot" id="midiStatusDot"></div>
      <span data-midi-target="status" style="color:#a0a0cc;font-family:'Space Grotesk',sans-serif;font-size:0.9rem;">Connecting to MIDI devices...</span>
    </div>

    <div data-midi-target="deviceList" style="margin-bottom:24px;">
      <p style="color:#666688;font-size:0.9rem;">No MIDI devices found.</p>
    </div>

    <div style="background:#0a0a1a;border:1px solid #2a2a44;border-radius:8px;padding:24px;">
      <h4 style="color:#a0a0cc;margin:0 0 12px;font-family:'Space Grotesk',sans-serif;text-transform:uppercase;letter-spacing:0.08em;font-size:0.85rem;">Live Input</h4>
      <p style="color:#666688;font-size:0.85rem;margin:0 0 12px;">Press keys on your piano to test the connection:</p>
      <div data-midi-target="lastNote"
           style="font-size:2.5rem;color:#00f0ff;text-align:center;padding:20px 20px 8px;min-height:70px;font-family:'Space Grotesk',sans-serif;font-weight:700;text-shadow:0 0 10px rgba(0,240,255,0.4);">
        —
      </div>
      <div style="padding:0 20px 20px;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;">
          <span style="color:#666688;font-size:0.8rem;font-family:'Space Grotesk',sans-serif;text-transform:uppercase;letter-spacing:0.05em;">Velocity</span>
          <span data-midi-target="velocity" style="color:#a0a0cc;font-size:0.85rem;font-weight:600;font-family:'Space Grotesk',sans-serif;">—</span>
        </div>
        <div style="height:6px;background:#1a1a2e;border-radius:3px;overflow:hidden;">
          <div data-midi-target="velocityBar"
               style="height:100%;width:0%;background:linear-gradient(90deg,#ff00ff,#00f0ff);border-radius:3px;transition:width 0.1s;">
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="neon-card" style="padding:24px;">
    <h3 style="color:#a0a0cc;margin:0 0 16px;font-size:1rem;text-transform:uppercase;letter-spacing:0.08em;">Troubleshooting</h3>
    <ul style="color:#a0a0cc;line-height:2.2;margin:0;padding-left:20px;font-size:0.9rem;">
      <li>Connect your piano via USB before loading this page</li>
      <li>Use <span style="color:#00f0ff;">Chrome</span> or <span style="color:#00f0ff;">Edge</span> (Firefox has limited WebMIDI support)</li>
      <li>Click <span style="color:#39ff14;">"Allow"</span> when the browser requests MIDI access</li>
      <li>Try disconnecting and reconnecting the USB cable</li>
    </ul>
  </div>
</div>
